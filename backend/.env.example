# Google Gemini
GEMINI_API_KEY=

# Langfuse — observability + hosted prompt management (optional)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Database (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=lynx
DB_USER=postgres
DB_PASSWORD=

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.your-domain.example

# Server (optional — Cloud Run injects PORT; CORS_ORIGIN for the deployed frontend)
# PORT=8080
# CORS_ORIGIN=http://localhost:3000
